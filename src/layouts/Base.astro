---
import '../styles/global.css';
import { SITE, NAV } from '../lib/site';
import { SOURCES, DRIFTED } from '../lib/sources';

interface Props {
  title: string;
  description: string;
  /** Path only, e.g. "/ai-implementation-cost". */
  path: string;
  /** JSON-LD nodes to place in @graph. */
  schema?: unknown[];
  noindex?: boolean;
}

const { title, description, path, schema = [], noindex = false } = Astro.props;
const canonical = `${SITE.url}${path}`;
const graph = schema.length ? { '@context': 'https://schema.org', '@graph': schema } : null;
const year = new Date().getFullYear();
const totalSources = SOURCES.length;
const drifted = DRIFTED.length;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.brand} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#f3f0e9" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#14130f" media="(prefers-color-scheme: dark)" />

    {graph && <script type="application/ld+json" set:html={JSON.stringify(graph)} />}
      <!-- GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-B9H1038L0H"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-B9H1038L0H');
    </script>
  </head>

  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header
      class="z-40 border-b sm:sticky sm:top-0"
      style="border-color: var(--color-hairline); background: var(--color-bg)"
    >
      <div class="mx-auto flex max-w-6xl flex-wrap items-center gap-x-6 gap-y-3 px-4 py-3.5">
        <a
          href="/"
          class="no-underline"
          style="background-image: none; font-family: var(--font-mono); color: var(--color-ink); font-weight: 600; font-size: 1.02rem; letter-spacing: -0.02em;"
        >
          implementai<span style="color: var(--color-accent)">.today</span>
        </a>

        <nav aria-label="Primary" class="order-3 w-full overflow-x-auto md:order-none md:w-auto">
          <ul class="flex items-center gap-5 whitespace-nowrap text-sm">
            {
              NAV.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="no-underline"
                    style={`background-image: none; color: ${path === item.href ? 'var(--color-accent)' : 'var(--color-muted)'}`}
                    aria-current={path === item.href ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>

        <a href="/ai-project-risk-diagnostic" class="btn btn-primary ml-auto text-sm">
          Free risk diagnostic
          <span class="btn-arrow" aria-hidden="true">&rarr;</span>
        </a>
      </div>

      <!-- Status ticker: the value proposition, always in view. Hidden on the smallest screens to keep the sticky header slim. -->
      <div class="hidden border-t sm:block" style="border-color: var(--color-hairline); background: var(--color-surface)">
        <div class="mx-auto flex max-w-6xl items-center gap-x-5 gap-y-1 overflow-x-auto whitespace-nowrap px-4 py-1.5">
          <span class="ticker" style="color: var(--color-accent)">&#9679; live corpus</span>
          <span class="ticker"><b class="num">{totalSources}</b> primary sources</span>
          <span class="ticker"><b class="num" style="color: var(--color-danger)">{drifted}</b> misquoted in the wild</span>
          <span class="ticker">every figure links its source</span>
          <span class="ticker" style="margin-left: auto">checked <b class="num">2026-07-10</b></span>
        </div>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="mt-28 border-t" style="border-color: var(--color-hairline)">
      <div class="rule-ticks"></div>
      <div class="grid-bg">
        <div class="mx-auto max-w-6xl px-4 py-12">
          <div class="grid gap-10 md:grid-cols-[1.4fr_1fr]">
            <div>
              <a
                href="/"
                class="no-underline"
                style="background-image: none; font-family: var(--font-mono); color: var(--color-ink); font-weight: 600; font-size: 1.05rem; letter-spacing: -0.02em;"
              >
                implementai<span style="color: var(--color-accent)">.today</span>
              </a>
              <p class="mt-3 max-w-md text-sm" style="color: var(--color-ink)">{SITE.tagline}</p>
              <p class="overline overline-tick overline-muted mt-6">Standing disclosure</p>
              <p class="mt-2 max-w-lg text-sm" style="color: var(--color-muted)">
                {SITE.disclosure}
              </p>
            </div>

            <nav aria-label="Footer">
              <p class="overline overline-muted">Pages</p>
              <ul class="mt-3 grid gap-y-2 text-sm">
                {
                  NAV.map((item) => (
                    <li>
                      <a href={item.href} class="no-underline" style="background-image: none; color: var(--color-muted)">
                        {item.label}
                      </a>
                    </li>
                  ))
                }
                <li><a href="/about" class="no-underline" style="background-image: none; color: var(--color-muted)">About and method</a></li>
              </ul>
            </nav>
          </div>

          <hr class="mt-10" />
          <p class="mt-6 text-xs" style="color: var(--color-muted)">
            <span class="num">&copy; {year}</span> {SITE.brand}. Written by
            <a href="/about">{SITE.author.name}</a>. Figures belong to the organisations that published them.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
